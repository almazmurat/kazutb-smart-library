# ============================================================
# KazUTB Smart Library — Root Environment Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://kazutb_user:change_this_password@localhost:5432/kazutb_library

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret_min_64_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# ─── LDAP / Active Directory ─────────────────────────────────
# University LDAP connection. Use LDAPs (port 636) in production.
LDAP_URL=ldaps://ldap.university.edu:636
LDAP_BIND_DN=cn=lib-service,ou=service-accounts,dc=university,dc=edu
LDAP_BIND_PASSWORD=replace_with_service_account_password
LDAP_BASE_DN=dc=university,dc=edu
LDAP_USERS_OU=ou=users,dc=university,dc=edu
LDAP_SEARCH_FILTER=(&(objectClass=user)(objectCategory=person)(sAMAccountName={{username}})(!(userAccountControl:1.2.840.113556.1.4.803:=2)))
LDAP_TLS_REJECT_UNAUTHORIZED=true
# In development, set LDAP_DEV_MOCK=true to bypass real LDAP
LDAP_DEV_MOCK=true

# ─── File Storage ────────────────────────────────────────────
# Local path for protected digital materials (PDFs, scans)
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=200

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ─── Docker Compose ──────────────────────────────────────────
# Overrides for docker-compose.yml (optional, defaults shown)
POSTGRES_USER=kazutb_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=kazutb_library
POSTGRES_PORT=5432
BACKEND_PORT=3000
FRONTEND_PORT=5173
